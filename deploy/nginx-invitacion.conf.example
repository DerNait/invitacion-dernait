# ==========================================================================
# Vhost para el nginx del HOST (reverse proxy).
# Colócalo en /etc/nginx/sites-available/invitacion y enlázalo a sites-enabled,
# o en /etc/nginx/conf.d/invitacion.conf según tu distro.
#
# 1) Cambia "invitacion.tudominio.com" por tu dominio/subdominio.
# 2) Apunta el DNS del dominio a la IP del VPS (registro A).
# 3) nginx -t && systemctl reload nginx
# 4) Genera el certificado:  certbot --nginx -d invitacion.tudominio.com
#    (certbot reescribe este archivo para añadir el bloque 443 + redirección)
# ==========================================================================

server {
    listen 80;
    listen [::]:80;
    server_name invitacion.tudominio.com;

    # Límite de subida (por si luego subes imágenes grandes)
    client_max_body_size 20M;

    location / {
        proxy_pass http://127.0.0.1:8090;   # <- APP_PORT del docker-compose.prod.yml
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
    }
}
