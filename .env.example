APP_NAME="Invitación Mundialista"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=invitacion
DB_USERNAME=invitacion
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo: por defecto "log" (se guarda en storage/logs). Cambia a "resend" cuando tengas la API key.
MAIL_MAILER=log
RESEND_API_KEY=
MAIL_FROM_ADDRESS="invitacion@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Admins del panel (se crean con el seeder). Todos reciben el aviso de cada confirmación.
ADMIN_EMAIL="tucorreo@gmail.com"
ADMIN_PASSWORD=
ADMIN_NAME="Anfitrión"

# Segundo admin (opcional). Déjalo vacío si no quieres un segundo.
ADMIN2_EMAIL=""
ADMIN2_PASSWORD=
ADMIN2_NAME="Anfitrión 2"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
