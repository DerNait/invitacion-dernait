# ==========================================================================
# .env de PRODUCCIÓN — copia este archivo a ".env" en el servidor y complétalo.
#   cp .env.production.example .env
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate
# ==========================================================================

APP_NAME="Invitación Mundialista"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Tu dominio real con https://
APP_URL=https://invitacion.tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# --- Base de datos (no se expone al exterior; usa una contraseña fuerte) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=invitacion
DB_USERNAME=invitacion
DB_PASSWORD=CAMBIA_ESTA_CLAVE_FUERTE
DB_ROOT_PASSWORD=CAMBIA_ESTA_CLAVE_ROOT

# --- Sesión / caché / cola ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Correos (Resend) ---
MAIL_MAILER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM_ADDRESS="invitacion@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Admins del panel (se crean con el seeder; todos reciben los avisos) ---
ADMIN_EMAIL="tucorreo@gmail.com"
ADMIN_PASSWORD="una-clave-segura"
ADMIN_NAME="Anfitrión"

ADMIN2_EMAIL=""
ADMIN2_PASSWORD="una-clave-segura-2"
ADMIN2_NAME="Anfitrión 2"

# --- Puerto local donde escucha el contenedor (el nginx del host hace proxy aquí) ---
APP_PORT=8090

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Datos del evento (opcional: ya tienen valores por defecto en config/event.php).
# Descomenta y ajusta si prefieres manejarlos por variables de entorno.
# ---------------------------------------------------------------------------
# EVENT_HOST_NAME="Kevin"
# EVENT_DATETIME="2026-06-20 13:00:00"
# EVENT_MAP_LAT=14.571603970040183
# EVENT_MAP_LNG=-90.5240814777078
